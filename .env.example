# === Database ===
DATABASE_URL=postgres://regelrecht:regelrecht_dev@localhost:5432/regelrecht_pipeline

# === GitHub Token (required for Docker builds of admin + frontend) ===
# Needs read:packages scope to pull @minbzk/storybook from GitHub Packages
GITHUB_TOKEN=ghp_your_token_here

# === Worker Configuration ===
REGULATION_REPO_PATH=./regulation-repo
REGULATION_OUTPUT_BASE=regulation/nl
WORKER_POLL_INTERVAL_SECS=5
WORKER_MAX_POLL_INTERVAL_SECS=60

# === Enrich Worker: LLM Provider ===
# LLM_PROVIDER=opencode
# OPENCODE_MODEL=vlam/ubiops-deployment/bzk-dig-mistralmedium-flexibel//chat-model

# === Enrich Worker: VLAM API Key (for opencode provider) ===
# VLAM_API_KEY=
# VLAM_BASE_URL=

# === Enrich Worker: Anthropic API Key (for claude provider) ===
# ANTHROPIC_API_KEY=

# === Host port overrides (change if defaults collide with other services) ===
# ADMIN_PORT=8000
# FRONTEND_PORT=3000
# GRAFANA_PORT=3001
# PROMETHEUS_PORT=9090
