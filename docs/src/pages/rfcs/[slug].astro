---
import { getCollection, render } from 'astro:content';
import Base from '~/layouts/Base.astro';
import DocsSidebar from '~/components/DocsSidebar.astro';
import DocsOutline from '~/components/DocsOutline.astro';
import DocsFooter from '~/components/DocsFooter.astro';
import { sidebarForPath } from '~/lib/sidebar';

export async function getStaticPaths() {
  const rfcs = await getCollection('rfcs');
  return rfcs.map((entry) => ({
    // rfcs.ts derives links as /rfcs/<filename-without-.md>; match exactly.
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const pathname = '/rfcs/' + entry.id.replace(/\.md$/, '');
const groups = sidebarForPath('/rfcs/');

const title =
  (headings.find((h) => h.depth === 1)?.text ?? entry.id) + ' · RegelRecht';
---

<Base
  lang="en"
  kind="docs"
  pathname={pathname}
  title={title}
>
  {groups && <DocsSidebar groups={groups} pathname={pathname} />}
  <div class="rr-docs-body">
    <main class="vp-doc rr-docs-content">
      <Content />
      <DocsFooter
        entryId={entry.id}
        collection="rfcs"
        pathname={pathname}
      />
    </main>
  </div>
  <DocsOutline headings={headings} />
</Base>
