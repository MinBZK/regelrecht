---
import { getCollection, render } from 'astro:content';
import Base from '~/layouts/Base.astro';
import DocsOutline from '~/components/DocsOutline.astro';
import EditLink from '~/components/EditLink.astro';
import DocsFooter from '~/components/DocsFooter.astro';
import { statusColor, statusLabel } from '~/lib/rfc-status';

export async function getStaticPaths() {
  const rfcs = await getCollection('rfcs');
  return rfcs.map((entry) => ({
    // rfcs.ts derives links as /rfcs/<filename-without-.md>; match exactly.
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const pathname = '/rfcs/' + entry.id.replace(/\.md$/, '');
// Edit-link base for this page (whole-file sidebar link + the per-selection
// line-range affordance both build off it).
const editBase = entry.filePath
  ? `https://github.com/MinBZK/regelrecht/edit/main/docs/${entry.filePath}`
  : undefined;
// Frontmatter strings may use `&shy;` as a readable marker for U+00AD
// (soft hyphen); the browser only renders the hyphen when the word needs
// to break.
const shy = (s: string | undefined) => s?.replace(/&shy;/g, '\u00AD');
const pageTitle =
  shy(entry.data.title) ??
  headings.find((h) => h.depth === 1)?.text ??
  entry.id;
const title = pageTitle + ' · RegelRecht';

// RFC preamble: the body opens with `**Status:** … **Date:** … **Authors:** …`.
// Surface Status as a coloured tag and the rest as a line in the section header
// (under the title); rehype-rfc-meta strips it from the body so it isn't shown
// twice.
function parseRfcPreamble(body: string): { status: string; line: string } | null {
  const fields: Record<string, string> = {};
  for (const raw of body.split('\n')) {
    const line = raw.trim();
    if (!line) {
      if (Object.keys(fields).length) break;
      continue;
    }
    if (line.startsWith('#')) break;
    const m = line.match(/^\*\*\s*([^:*]+?)\s*:\*\*\s*(.+?)\s*$/);
    if (m) {
      fields[m[1]] = m[2];
      continue;
    }
    if (Object.keys(fields).length) break;
  }
  if (!fields.Status) return null;
  const rest = Object.entries(fields)
    .filter(([k]) => k !== 'Status' && k !== 'Short title')
    .map(([k, v]) => `${k}: ${v}`)
    .join('  ·  ');
  return { status: fields.Status, line: rest };
}
// `entry.body` isn't populated by the glob loader here, so pull the raw RFC
// source via Vite (?raw) and parse the preamble from it (frontmatter stripped).
const rfcRawFiles = import.meta.glob('/src/content/rfcs/*.md', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;
const rfcRawBody = (rfcRawFiles['/' + entry.filePath] ?? '').replace(
  /^---\r?\n[\s\S]*?\r?\n---\r?\n/,
  '',
);
const rfcMeta = parseRfcPreamble(rfcRawBody);
---

<Base lang="en" kind="docs" pathname={pathname} title={title}>
  <nldd-one-third-two-thirds-section
    sm-padding-bottom="32"
    md-padding-bottom="64"
    lg-padding-bottom="96"
  >
    <nldd-title slot="header" size="1">
      <h1>{pageTitle}</h1>
    </nldd-title>
    {rfcMeta && <nldd-spacer slot="header" size="8"></nldd-spacer>}
    {rfcMeta && (
      <nldd-tag slot="header" color={statusColor(rfcMeta.status)} size="md">{statusLabel(rfcMeta.status)}</nldd-tag>
    )}
    {rfcMeta?.line && <nldd-spacer slot="header" size="8"></nldd-spacer>}
    {rfcMeta?.line && (
      <nldd-rich-text slot="header">
        <p>{rfcMeta.line}</p>
      </nldd-rich-text>
    )}
    <div slot="left">
      <DocsOutline headings={headings} />
      <nldd-spacer size="24" sm-size="16" />
      <EditLink filePath={entry.filePath} />
    </div>
    <div slot="right" class="rr-min-width-0">
      <nldd-rich-text data-edit-base={editBase}>
        <Content />
      </nldd-rich-text>
      <DocsFooter pathname={pathname} />
    </div>
  </nldd-one-third-two-thirds-section>
</Base>
