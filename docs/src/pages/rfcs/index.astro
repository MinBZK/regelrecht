---
/*
 * RFC overview — a category page (like /guide/, /concepts/, …). The RFCs are
 * listed as a boxed navigation list; getRfcs() runs at build time.
 */
import Base from '~/layouts/Base.astro';
import { getRfcs } from '~/lib/rfcs';

const pathname = '/rfcs/';
const rfcs = getRfcs();

const statusColor = (s: string) => {
  const k = (s ?? '').toLowerCase();
  if (k.includes('accept')) return 'success';
  if (k.includes('propos')) return 'accent';
  if (k.includes('reject')) return 'critical';
  if (k.includes('supersed')) return 'warning';
  return 'neutral';
};
---

<Base
  lang="en"
  kind="docs"
  pathname={pathname}
  title="RFCs · RegelRecht"
  description="Design decisions in RegelRecht, documented through RFCs."
>
  <nldd-one-third-two-thirds-section>
    <div slot="left">
      <nldd-title size="2">
        <h1>RFCs</h1>
      </nldd-title>
      <nldd-spacer />
      <nldd-rich-text>
        <p>
          Design decisions in RegelRecht are documented through RFCs. Each RFC
          captures the problem, the considered alternatives, and the chosen
          approach.
        </p>
        <p>
          See <a href="/rfcs/rfc-000">RFC-000</a> for the process and template.
        </p>
      </nldd-rich-text>
    </div>
    <div slot="right">
      <nldd-list type="navigation" variant="box">
        {
          rfcs.map((r) => (
            <nldd-list-item href={r.link}>
              <nldd-text-cell overline={r.id} text={r.title} width="full" />
              <nldd-spacer-cell />
              <nldd-cell>
                <nldd-tag color={statusColor(r.status)} size="md">
                  {r.status}
                </nldd-tag>
              </nldd-cell>
              <nldd-spacer-cell />
              <nldd-icon-cell icon="chevron-right" />
            </nldd-list-item>
          ))
        }
      </nldd-list>
    </div>
  </nldd-one-third-two-thirds-section>
</Base>
