---
/*
 * RFC overview — a category page (like /guide/, /concepts/, …). The RFCs are
 * listed as a boxed navigation list; getRfcs() runs at build time.
 */
import Base from '~/layouts/Base.astro';
import EditLink from '~/components/EditLink.astro';
import { getRfcs, rfcStatusColor } from '~/lib/rfcs';

const pathname = '/rfcs/';
const rfcs = getRfcs();
---

<Base
  lang="en"
  kind="docs"
  pathname={pathname}
  title="RFCs · RegelRecht"
  description="Design decisions in RegelRecht, documented through RFCs."
>
  <nldd-one-third-two-thirds-section
    sm-padding-bottom="32"
    md-padding-bottom="64"
    lg-padding-bottom="96"
  >
    <div slot="left">
      <nldd-title size="2">
        <h1>RFCs</h1>
      </nldd-title>
      <nldd-spacer />
      <nldd-rich-text>
        <p>
          Design decisions in RegelRecht are documented through RFCs. Each RFC
          captures the problem, the considered alternatives, and the chosen
          approach.
        </p>
        <p>
          See <a href="/rfcs/rfc-000">RFC-000</a> for the process and template.
        </p>
      </nldd-rich-text>
      <nldd-spacer size="24" sm-size="16" />
      <EditLink filePath="src/content/rfcs/index.md" />
    </div>
    <div slot="right">
      <nldd-list type="navigation" variant="box">
        {
          rfcs.map((r) => (
            <nldd-list-item href={r.link}>
              <nldd-text-cell overline={r.id} text={r.title} width="full">
                <span slot="supporting-text" class="rr-rfc-tags">
                  <nldd-tag color={rfcStatusColor(r.status)} size="md">
                    {r.status}
                  </nldd-tag>
                  {r.implementation && (
                    <nldd-tag color="neutral" size="md">
                      {r.implementation}
                    </nldd-tag>
                  )}
                </span>
              </nldd-text-cell>
              <nldd-spacer-cell />
              <nldd-icon-cell icon="chevron-right" />
            </nldd-list-item>
          ))
        }
      </nldd-list>
    </div>
  </nldd-one-third-two-thirds-section>
</Base>
