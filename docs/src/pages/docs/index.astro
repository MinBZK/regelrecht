---
import Base from '~/layouts/Base.astro';
import { docsNav } from '~/lib/navLinks';

// Top-level documentation overview: every category, linking to its category
// (overview) page. Home is excluded — it's the site landing, not a category.
const categories = docsNav.filter((n) => n.match !== '/en/');
const title = 'Documentation · RegelRecht';
---

<Base lang="en" kind="docs" pathname="/docs/" title={title}>
  <nldd-one-third-two-thirds-section
    sm-padding-bottom="32"
    md-padding-bottom="64"
    lg-padding-bottom="96"
  >
    <div slot="left">
      <nldd-title size="2">
        <h1>Documentation</h1>
      </nldd-title>
    </div>
    <div slot="right">
      <nldd-list type="navigation" variant="box">
        {
          categories.map((c) => (
            <nldd-list-item href={c.match ?? c.link}>
              <nldd-text-cell
                text={c.text}
                supporting-text={c.summary}
                width="full"
              />
              <nldd-spacer-cell />
              <nldd-icon-cell size="20" icon="chevron-right" />
            </nldd-list-item>
          ))
        }
      </nldd-list>
    </div>
  </nldd-one-third-two-thirds-section>
</Base>
