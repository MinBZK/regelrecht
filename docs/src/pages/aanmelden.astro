---
import Base from '~/layouts/Base.astro';
import LandingSections from '~/components/LandingSections.astro';
import Footer from '~/components/Footer.astro';
import { content } from '~/lib/landing-content';

const t = content.nl;
const title = `${t.nav.signup} — RegelRecht`;
const description = t.signup.lede;
---

<Base
  lang="nl"
  kind="landing"
  pathname="/aanmelden"
  title={title}
  description={description}
>
  <LandingSections lang="nl" showSignup={true} />
  <Footer lang="nl" />
</Base>
