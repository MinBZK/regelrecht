{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://regelrecht.rijks.app/architecture/model.schema.json",
  "title": "Regelrecht architecture model",
  "description": "Code-derived, language-agnostic architecture model for the regelrecht workspace. Generated by packages/arch-extract; do not hand-edit — run `just arch-generate`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "nodes", "edges"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": {
      "type": "string",
      "description": "Shape version of this document, bumped when the model structure changes."
    },
    "generatedAt": {
      "type": "string",
      "description": "Optional ISO-8601 timestamp added by CI. The generator itself never writes this (a timestamp would make every regeneration a diff)."
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/definitions/edge" }
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "level", "kind", "lang", "name", "path"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable path-style id, e.g. `crate:engine`, `mod:engine::service`, `type:engine::service::LawExecutionService`, `fn:engine::service::LawExecutionService::execute`."
        },
        "level": {
          "type": "string",
          "enum": ["system", "container", "component", "code"]
        },
        "kind": {
          "type": "string",
          "enum": ["crate", "binary", "module", "struct", "enum", "trait", "method", "fn"]
        },
        "lang": { "type": "string" },
        "name": { "type": "string" },
        "path": {
          "type": "string",
          "description": "Repo-relative source location (directory for crates, file otherwise)."
        },
        "parent": {
          "type": "string",
          "description": "Id of the containing node; absent for top-level crates/binaries."
        },
        "doc": {
          "type": "string",
          "description": "First line of the item's doc-comment, seeding the prose layer."
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "kind"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["depends-on", "impl", "uses", "calls"]
        }
      }
    }
  }
}
