---
/*
 * Doc page footer wrapper, ported from the relanding RrDocFooter.vue
 * outer <footer class="rr-doc-footer">: edit-on-GitHub link above the
 * prev/next pager, separated from the body by a top border.
 */
import EditLink from './EditLink.astro';
import DocsPrevNext from './DocsPrevNext.astro';

interface Props {
  entryId: string;
  collection: 'docs' | 'rfcs';
  pathname: string;
}
const { entryId, collection, pathname } = Astro.props;
---

<footer class="rr-doc-footer">
  <EditLink entryId={entryId} collection={collection} />
  <DocsPrevNext pathname={pathname} />
</footer>

<style>
  .rr-doc-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--vp-c-divider);
  }
</style>
