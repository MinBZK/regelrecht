---
/* Ported verbatim from the relanding RrFooter.vue <template>. */
import { content } from '~/lib/landing-content';

interface Props {
  lang: 'nl' | 'en';
}
const { lang } = Astro.props;
const f = content[lang].footer;
---

<nldd-simple-section
  background="tinted"
  scheme="dark"
  sm-padding-top="32"
  md-padding-top="64"
  lg-padding-top="96"
>
  <div class="rr-footer-grid">
    <div>
      <nldd-title size="5"><h5>RegelRecht</h5></nldd-title>
      <nldd-spacer size="12" />
      <nldd-rich-text><p>{f.blurb}</p></nldd-rich-text>
    </div>
    <div>
      <nldd-title size="5"><h5>{f.linksTitle}</h5></nldd-title>
      <nldd-spacer size="12" />
      <nldd-rich-text>
        <p>
          {
            f.links.map((l, i) => (
              <Fragment>
                {i > 0 && <br />}
                <a href={l.href}>{l.label}</a>
              </Fragment>
            ))
          }
        </p>
      </nldd-rich-text>
    </div>
    <div>
      <nldd-title size="5"><h5>{f.contactTitle}</h5></nldd-title>
      <nldd-spacer size="12" />
      <nldd-rich-text>
        <p>
          <a href="mailto:regelrecht@minbzk.nl">regelrecht@minbzk.nl</a>
        </p>
      </nldd-rich-text>
    </div>
    <div>
      <nldd-title size="5"><h5>{f.partOfTitle}</h5></nldd-title>
      <nldd-spacer size="12" />
      <nldd-rich-text>
        <p>
          {
            f.partOf.map((o, i) => (
              <Fragment>
                {i > 0 && <br />}
                {o}
              </Fragment>
            ))
          }
        </p>
      </nldd-rich-text>
    </div>
  </div>
  <nldd-spacer size="24" />
  <nldd-divider></nldd-divider>
  <nldd-spacer size="24" />
  <div class="rr-footer-bottom">
    <nldd-rich-text>
      <small>{f.copyright}</small>
    </nldd-rich-text>
  </div>
</nldd-simple-section>
