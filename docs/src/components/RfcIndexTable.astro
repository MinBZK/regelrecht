---
/*
 * RFC overview table. The relanding version fed this from a VitePress
 * data loader; here getRfcs() is called directly at build time (it is
 * pure Node, reads docs/src/content/rfcs/rfc-*.md). Same columns the
 * loader produced: id, title, status, link.
 */
import { getRfcs } from '~/lib/rfcs';

const rfcs = getRfcs();
---

{/* Same focusable scroll wrapper rehypeTableScroll adds to markdown tables, so
    this hand-built table is keyboard-scrollable when it overflows (WCAG 2.1.1). */}
<div class="rr-table-scroll" tabindex="0">
  <table class="rr-rfc-table">
    <thead>
      <tr>
        <th scope="col">RFC</th>
        <th scope="col">Title</th>
        <th scope="col">Status</th>
      </tr>
    </thead>
    <tbody>
      {
        rfcs.map((r) => (
          <tr>
            <td>
              <a href={r.link}>{r.id}</a>
            </td>
            <td>{r.title}</td>
            <td>{r.status}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .rr-rfc-table {
    width: 100%;
    border-collapse: collapse;
    /* Margin lives on the .rr-table-scroll wrapper (global docs.css), not the
       table, so the focusable wrapper and the table don't double up. */
    margin: 0;
  }
  .rr-rfc-table th,
  .rr-rfc-table td {
    text-align: left;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--vp-c-divider);
    vertical-align: top;
  }
  .rr-rfc-table th {
    font-weight: 600;
    background: var(--vp-c-bg-soft);
  }
  .rr-rfc-table a {
    color: var(--vp-c-brand-1);
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
  }
  :global(.dark) .rr-rfc-table a {
    color: var(--vp-c-brand-2);
  }
  .rr-rfc-table a:hover {
    text-decoration: underline;
  }
</style>
