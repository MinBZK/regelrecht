---
/*
 * Ported from the relanding RrDocFooter.vue prev/next nav. The flattened
 * sidebar order is the navigation order; prev/next are the neighbours of
 * the current pathname. The edit-link prose is a sibling <EditLink>
 * rendered by the page above this component (same as the Vue footer
 * grouped both).
 */
import { flatSidebar } from '~/lib/sidebar';

interface Props {
  pathname: string;
}
const { pathname } = Astro.props;

function norm(p: string) {
  return p.replace(/(index)?\.(md|html)$/, '').replace(/\/$/, '');
}

const flat = flatSidebar(pathname);
const idx = flat.findIndex((l) => norm(l.link) === norm(pathname));
const prev = idx > 0 ? flat[idx - 1] : null;
const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;
---

{(prev || next) && (
  <nldd-toolbar aria-label="Pagination">
    {prev && (
      <nldd-toolbar-item slot="start" label={prev.text}>
        <nldd-button href={prev.link} start-icon="arrow-left" text={prev.text} />
      </nldd-toolbar-item>
    )}
    {next && (
      <nldd-toolbar-item slot="end" label={next.text}>
        <nldd-button href={next.link} end-icon="arrow-right" text={next.text} />
      </nldd-toolbar-item>
    )}
  </nldd-toolbar>
)}
