---
/*
 * Landing page content, ported verbatim from the relanding LandingPage.vue
 * <template>. Wrapper/skip-link/nav/footer live in Base.astro. NLDD elements
 * render their slotted content in light DOM so the real headings/paragraphs
 * are server-rendered and work without JS; only nldd-button is the
 * exception, so every button ships a real <a> fallback next to the
 * <nldd-button> and CSS shows exactly one (see landing.css).
 */
import { content } from '~/lib/landing-content';
import SignupForm from './SignupForm.astro';

interface Props {
  lang: 'nl' | 'en';
  showSignup: boolean;
}

const { lang, showSignup } = Astro.props;
const t = content[lang];
const home = lang === 'en' ? '/en/' : '/';

// TEMP new hero: full table of contents — every landing section's title.
const toc = [
  { text: t.whatIsIt.title, href: '#what-is-it' },
  { text: t.whyImportant.title, href: '#why-important' },
  { text: t.howItWorks.title, href: '#how-it-works' },
  { text: t.tools.title, href: '#tools' },
  { text: t.example.title, href: '#example' },
  { text: t.innovation.title, href: '#innovation' },
  { text: t.references.title, href: '#references' },
  { text: t.faq.title, href: '#faq' },
  { text: t.feedback.title, href: '#feedback' },
];
---

{
  showSignup ? (
      <section class="rr-section" aria-labelledby="rr-signup-title">
        <nldd-container padding="0" class="rr-container">
          <nldd-title size="1">
            <h1 id="rr-signup-title" class="rr-section-title">
              {t.signup.pageTitle}
            </h1>
          </nldd-title>
          <nldd-rich-text>
            <p class="rr-lede">{t.signup.lede}</p>
          </nldd-rich-text>
          <SignupForm lang={lang} />
          <noscript>
            <p>{t.signup.noscript}</p>
          </noscript>
        </nldd-container>
      </section>
    ) : (
      <Fragment>
        {/* TEMP: new design-system hero, shown above the existing hero.
            Forced dark two ways: color-scheme:dark drives the NLDD tokens
            (built on light-dark()), and the `dark` theme class re-defines the
            docs' own --vp-* vars (which colour the slotted headings/body). */}
        <nldd-two-thirds-one-third-section
          class="dark"
          style="color-scheme: dark; background: var(--semantics-surfaces-background-color);"
        >
          <div slot="left">
            <nldd-title size="1">
              <h1>RegelRecht</h1>
              <p slot="subtitle">{t.hero.titleSmall}</p>
            </nldd-title>
            <nldd-spacer size="24" />
            <nldd-rich-text>
              <p>{t.hero.intro}</p>
            </nldd-rich-text>
            <nldd-spacer size="24" />
            <nldd-button-group orientation="horizontal">
              <nldd-button
                variant="primary"
                href={home + '#what-is-it'}
                text={t.hero.cta}
              />
              <nldd-button
                variant="secondary"
                href={t.feedback.ctaHref}
                text={t.feedback.cta}
              />
            </nldd-button-group>
            <nldd-spacer size="24" />
            <nldd-rich-text>
              <p>
                {t.partners.label}{' '}
                {t.partners.items.map((p, i) => {
                  const sep =
                    i === 0
                      ? ''
                      : i === t.partners.items.length - 1
                        ? lang === 'en'
                          ? ', and '
                          : ' en '
                        : ', ';
                  return (<Fragment>{sep}<a href={p.href}>{p.label}</a></Fragment>);
                })}
              </p>
            </nldd-rich-text>
          </div>
          <nldd-list slot="right" type="navigation">
            {toc.map((item) => (
              <nldd-list-item href={item.href}>
                <nldd-text-cell text={item.text} />
              </nldd-list-item>
            ))}
          </nldd-list>
        </nldd-two-thirds-one-third-section>

        <nldd-simple-section id="what-is-it">
          <nldd-title size="2">
            <h2>{t.whatIsIt.title}</h2>
          </nldd-title>
          <nldd-spacer />
          <nldd-rich-text>
            <p>{t.whatIsIt.lede}</p>
          </nldd-rich-text>
          <nldd-spacer size="24" />
          <nldd-collection layout="grid" item-width="320px">
            {t.whatIsIt.cards.map((c) => (
              <nldd-card accessible-label={c.h}>
                <nldd-container padding="16">
                  <nldd-title size="4">
                    <h3>{c.h}</h3>
                  </nldd-title>
                  <nldd-spacer size="8" />
                  <nldd-rich-text>
                    <p>{c.p}</p>
                  </nldd-rich-text>
                </nldd-container>
              </nldd-card>
            ))}
          </nldd-collection>
        </nldd-simple-section>

        <nldd-simple-section id="why-important">
          <nldd-title size="2">
            <h2>{t.whyImportant.title}</h2>
          </nldd-title>
          <nldd-spacer />
          <nldd-rich-text>
            <p>{t.whyImportant.lede}</p>
          </nldd-rich-text>
          <nldd-spacer size="24" />
          {t.whyImportant.problemSolutions.map((ps, i) => (
            <Fragment>
              {i > 0 && <nldd-spacer size="24" />}
              <nldd-collection layout="grid" item-width="480px">
                <nldd-card accessible-label={ps.problemTitle}>
                  <nldd-container padding="16">
                    <nldd-tag color="critical" size="md">
                      {lang === 'en' ? 'The problem' : 'Het probleem'}
                    </nldd-tag>
                    <nldd-spacer size="8" />
                    <nldd-title size="4">
                      <h3>{ps.problemTitle}</h3>
                    </nldd-title>
                    <nldd-spacer size="8" />
                    <nldd-rich-text>
                      <p>{ps.problemText}</p>
                    </nldd-rich-text>
                  </nldd-container>
                </nldd-card>
                <nldd-card accessible-label={ps.solutionTitle}>
                  <nldd-container padding="16">
                    <nldd-tag color="accent" size="md">
                      {lang === 'en' ? 'Possible direction' : 'Mogelijke richting'}
                    </nldd-tag>
                    <nldd-spacer size="8" />
                    <nldd-title size="4">
                      <h3>{ps.solutionTitle}</h3>
                    </nldd-title>
                    <nldd-spacer size="8" />
                    <nldd-rich-text>
                      <p>{ps.solutionText}</p>
                    </nldd-rich-text>
                  </nldd-container>
                </nldd-card>
              </nldd-collection>
            </Fragment>
          ))}
        </nldd-simple-section>

        <nldd-simple-section id="how-it-works" width="800px">
          <nldd-title size="2">
            <h2>{t.howItWorks.title}</h2>
          </nldd-title>
          <nldd-spacer />
          <nldd-rich-text>
            <p>{t.howItWorks.lede}</p>
          </nldd-rich-text>
          <nldd-spacer size="24" />
          <nldd-list no-dividers>
            {t.howItWorks.steps.map((step, i, arr) => (
              <nldd-list-item>
                <nldd-title-cell
                  text={String(i + 1)}
                  size="2"
                  width="fit-content"
                  vertical-alignment="center"
                />
                <nldd-spacer-cell size="16" />
                <nldd-timeline-track-cell
                  child={
                    i === 0 ? 'first' : i === arr.length - 1 ? 'last' : 'between'
                  }
                />
                <nldd-spacer-cell size="16" />
                <nldd-cell width="full" vertical-alignment="top">
                  <nldd-title size="5">
                    <h3>{step.title}</h3>
                  </nldd-title>
                  <nldd-rich-text>
                    <p>{step.text}</p>
                  </nldd-rich-text>
                </nldd-cell>
              </nldd-list-item>
            ))}
          </nldd-list>
        </nldd-simple-section>

        <nldd-simple-section id="tools">
          <nldd-title size="2">
            <h2>{t.tools.title}</h2>
          </nldd-title>
          <nldd-spacer size="24" />
          <nldd-collection layout="grid" item-width="320px">
            {t.tools.items.map((tool) => (
              <nldd-card accessible-label={tool.title}>
                <nldd-container padding="16">
                  <nldd-title size="4">
                    <h3>{tool.title}</h3>
                  </nldd-title>
                  {tool.meta && (
                    <Fragment>
                      <nldd-spacer size="8" />
                      <nldd-container
                        direction="row"
                        wrap
                        gap="6"
                        horizontal-alignment="left"
                      >
                        {tool.meta.split('•').map((tag) => (
                          <nldd-tag color="accent" size="md">
                            {tag.trim()}
                          </nldd-tag>
                        ))}
                      </nldd-container>
                    </Fragment>
                  )}
                  <nldd-spacer size="8" />
                  <nldd-rich-text>
                    <p>
                      {tool.text}{' '}
                      {tool.link && (
                        <a href={tool.link.href}>{tool.link.href.includes('github')
                          ? lang === 'en'
                            ? 'Check out our code on GitHub.'
                            : 'Bekijk onze code op GitHub.'
                          : lang === 'en'
                            ? 'See the live demo.'
                            : 'Bekijk de live demo.'}</a>
                      )}
                    </p>
                  </nldd-rich-text>
                </nldd-container>
              </nldd-card>
            ))}
          </nldd-collection>
        </nldd-simple-section>

        <section
          id="example"
          class="rr-section rr-section--alt"
          aria-labelledby="rr-example-title"
        >
          <nldd-container padding="0" class="rr-container">
            <nldd-title size="2">
              <h2 id="rr-example-title" class="rr-section-title">
                {t.example.title}
              </h2>
            </nldd-title>
            <nldd-rich-text>
              <p class="rr-lede">{t.example.lede}</p>
            </nldd-rich-text>

            {t.example.cases.map((ex) => (
              <div
                class:list={[
                  'rr-example',
                  { 'rr-example--reverse': ex.reverse },
                ]}
              >
                <figure>
                  <img src={ex.img} alt={ex.alt} />
                  <figcaption>{ex.caption}</figcaption>
                </figure>
                <nldd-rich-text>
                  <h3>{ex.h}</h3>
                  <p>{ex.p}</p>
                  <ul>
                    {ex.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                </nldd-rich-text>
              </div>
            ))}
          </nldd-container>
        </section>

        <section
          id="innovation"
          class="rr-section"
          aria-labelledby="rr-innovation-title"
        >
          <nldd-container padding="0" class="rr-container">
            <nldd-title size="2">
              <h2 id="rr-innovation-title" class="rr-section-title">
                {t.innovation.title}
              </h2>
            </nldd-title>
            <nldd-rich-text>
              <p class="rr-lede">
                {t.innovation.ledeBefore}
                <a href={t.innovation.ledeLink.href}>
                  {t.innovation.ledeLink.label}
                </a>
                {t.innovation.ledeAfter}
              </p>
            </nldd-rich-text>
            <nldd-collection layout="grid" item-width="300px" class="rr-grid">
              {t.innovation.cards.map((c) => (
                <nldd-card class="rr-card" accessible-label={c.h}>
                  <div class="rr-card-inner">
                    <nldd-tag color="accent" size="md">
                      {c.meta}
                    </nldd-tag>
                    <nldd-rich-text>
                      <h3>{c.h}</h3>
                      <p>{c.p}</p>
                    </nldd-rich-text>
                  </div>
                </nldd-card>
              ))}
            </nldd-collection>
          </nldd-container>
        </section>

        <section
          id="references"
          class="rr-section rr-section--alt"
          aria-labelledby="rr-refs-title"
        >
          <nldd-container padding="0" class="rr-container">
            <nldd-title size="2">
              <h2 id="rr-refs-title" class="rr-section-title">
                {t.references.title}
              </h2>
            </nldd-title>
            <nldd-rich-text>
              <p class="rr-lede">{t.references.lede}</p>
            </nldd-rich-text>
            <ul class="rr-refs">
              {t.references.items.map((ref) => (
                <li>
                  <nldd-rich-text>
                    <h3>{ref.title}</h3>
                    <p class="rr-ref-meta">{ref.meta}</p>
                    <p>{ref.text}</p>
                  </nldd-rich-text>
                  <a href={ref.href}>
                    {ref.linkLabel}
                    <span class="rr-visually-hidden">— {ref.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nldd-container>
        </section>

        <section
          id="faq"
          class="rr-section"
          aria-labelledby="rr-faq-title"
        >
          <nldd-container padding="0" class="rr-container">
            <nldd-title size="2">
              <h2 id="rr-faq-title" class="rr-section-title">
                {t.faq.title}
              </h2>
            </nldd-title>
            <div class="rr-faq">
              {t.faq.items.map((item) => (
                <details>
                  <summary>{item.q}</summary>
                  <nldd-rich-text>
                    <p>{item.a}</p>
                  </nldd-rich-text>
                </details>
              ))}
            </div>
          </nldd-container>
        </section>

        <section
          id="feedback"
          class="rr-section rr-section--alt rr-feedback"
          aria-labelledby="rr-feedback-title"
        >
          <nldd-container padding="0" class="rr-container">
            <nldd-title size="2">
              <h2 id="rr-feedback-title" class="rr-section-title">
                {t.feedback.title}
              </h2>
            </nldd-title>
            <nldd-rich-text>
              <p>{t.feedback.body}</p>
            </nldd-rich-text>
            <p class="rr-cta">
              <nldd-button
                class="rr-btn-wc"
                variant="primary"
                href={t.feedback.ctaHref}
                text={t.feedback.cta}
              />
              <a
                class="rr-btn rr-btn--primary rr-btn-fallback"
                href={t.feedback.ctaHref}
              >
                {t.feedback.cta}
              </a>
            </p>
          </nldd-container>
        </section>
      </Fragment>
    )
  }
