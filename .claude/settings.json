{
  "permissions": {
    "deny": [
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "pre-commit run"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "nldd-plugins": {
      "source": {
        "source": "github",
        "repo": "MinBZK/storybook"
      }
    }
  },
  "enabledPlugins": {
    "nldd@nldd-plugins": true
  }
}
