# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Claude Code
.claude/settings.local.json
.claude/*.local.*

# Logs
*.log

# Git worktrees
.worktrees/

# Browser automation artifacts (Playwright MCP / e2e smoke screenshots).
# The MCP server writes snapshots/screenshots here; keep them out of git.
.playwright-mcp/
.screenshots/

# Frontend
node_modules/
frontend/dist/
frontend/public/wasm/pkg/
packages/admin/static/

# Rust
target/
**/*.rs.bk
*.pdb
# Generated by `just dev-setup`: machine-local cargo config (shared target-dir,
# optional sccache wrapper). packages/.cargo/config.toml stays tracked.
/.cargo/

# Python (pre-commit uses a venv)
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
.ruff_cache/

# Mutation testing
mutants.out/

# BDD trace output
trace_output/

# Dev stack
.dev-pids

# Corpus local overrides
corpus-registry.local.yaml
corpus-auth.yaml

# Environment — ignore all .env files, keep the committed *.example templates
.env*
!.env*.example
# Local SSO secrets (no leading dot, so .env* above misses it)
env.sso-local

# Gemini CLI
.gemini/*
!.gemini/prompts/

# Beads
.beads/
.relanding-ref/

# Leak-guard laag 2 — casus-/sector-patronen blijven lokaal (zie script/check-skills-no-casus.sh)
script/.skills-casus-denylist.local

# Lokale DS-tarballs voor het testen van een storybook-branch (niet committen)
.ds-tarballs/
sync-ds.sh
